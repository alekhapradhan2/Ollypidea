# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/ollipedia?retryWrites=true&w=majority

# Secret key for JWT tokens — use a long random string
JWT_SECRET=your_super_secret_key_change_this_in_production_abc123xyz

# Your deployed frontend URL (for CORS)
FRONTEND_URL=https://your-ollipedia.vercel.app

# Port (Railway/Render set this automatically)
PORT=4000

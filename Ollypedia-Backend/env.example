# Ollypedia-Backend/.env.example
# Copy this to .env and fill in your values
# NEVER commit the actual .env file to git

MONGO_URI=mongodb+srv://ollipedia:YOUR_PASSWORD@cluster0.XXXXX.mongodb.net/ollipedia?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
PORT=4000
FRONTEND_URL=http://localhost:5173
ADMIN_REGISTER_SECRET=choose_a_secret_word_for_admin_registration
